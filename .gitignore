# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Cloudflare Wrangler ──────────────────────────────────────────────────────
.wrangler/

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Vite ─────────────────────────────────────────────────────────────────────
.vite/

# ─── Tauri / Rust ─────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/WixTools/
src-tauri/gen/           # Tauri auto-generated Android/iOS scaffolding
**/*.rs.bk
# Cargo.lock is intentionally committed for binary applications (ensures
# reproducible builds). Do NOT add it back to this ignore list.

# ─── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
# ASP.NET Core user secrets and local overrides
**/secrets.json
appsettings.Production.json
appsettings.Development.json
appsettings.Test.json

# ─── Local tooling config (may contain embedded credentials) ──────────────────
.claude/settings.local.json

# ─── IDE: VS Code ─────────────────────────────────────────────────────────────
# Shared project configs are tracked; personal overrides are not.
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/settings.json

# ─── IDE: JetBrains / Visual Studio ──────────────────────────────────────────
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ntvs*
*.njsproj
*.swp

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ─── Linux ────────────────────────────────────────────────────────────────────
*~

# ─── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── .NET: Build artifacts ────────────────────────────────────────────────────
api/src/*/bin/
api/src/*/obj/
api/tests/*/bin/
api/tests/*/obj/

# ─── .NET: Test results ───────────────────────────────────────────────────────
TestResults/
*.trx
*.coverage
*.coveragexml

# ─── .NET: NuGet ─────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
.nuget/packages/

# ─── .NET: Publish output ─────────────────────────────────────────────────────
api/publish/

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/
e2e-report/
.playwright-mcp/

# ─── SQLite ───────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.db-shm
*.db-wal
!src-tauri/resources/*.db
