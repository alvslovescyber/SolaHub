{
  "name": "solahub",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "VITE_WEB_ONLY=true vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:web": "vue-tsc --noEmit && VITE_WEB_ONLY=true vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "tauri:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "tauri:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "tauri:test": "cargo test --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
    "tauri:verify": "npm run tauri:fmt:check && npm run tauri:lint && npm run tauri:test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,css}\" \"e2e/**/*.ts\" \"*.config.{js,ts}\" \"playwright.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,css}\" \"e2e/**/*.ts\" \"*.config.{js,ts}\" \"playwright.config.ts\"",
    "type-check": "vue-tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run type-check && npm run test:run",
    "verify:api": "dotnet tool restore --tool-manifest api/.config/dotnet-tools.json && cd api && dotnet tool run csharpier check . && cd .. && dotnet test api/tests/SolaHub.Tests.Unit/SolaHub.Tests.Unit.csproj --configuration Release --no-restore",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@tauri-apps/api": "^2.1.1",
    "@vueuse/core": "^11.3.0",
    "axios": "^1.7.7",
    "date-fns": "^4.1.0",
    "jiti": "^2.6.1",
    "lucide-vue-next": "^0.453.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.2.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.1.10"
  }
}
