# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the SolaHub API. In Tauri production builds this will be the
# localhost port your API is running on. The tauri:// scheme is blocked for CORS
# so use http://localhost:PORT for development.
VITE_API_URL=http://localhost:3000

# ─── Native desktop updater (Tauri build-time environment) ───────────────────
# Generate the key pair with `npm run tauri signer generate -- -w ~/.tauri/solahub.key`.
# Keep the private key secret; only the public key below is compiled into the app.
# SOLAHUB_UPDATER_PUBLIC_KEY=PASTE_PUBLIC_KEY_FROM_SIGNER_GENERATE
# SOLAHUB_UPDATER_ENDPOINT=https://github.com/alvslovescyber/SolaHub/releases/latest/download/latest.json
# TAURI_SIGNING_PRIVATE_KEY=/Users/you/.tauri/solahub.key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# ─── API (appsettings.Development.json / environment variables) ───────────────
# These are set in appsettings.json / appsettings.Development.json or via
# environment variables. Copy the values below into your shell or a local
# docker-compose.override.yml file.

# ─── PostgreSQL — LOCAL DEV ───────────────────────────────────────────────────
# Local dev uses postgres (superuser). RLS is enabled but superusers bypass it,
# which is acceptable for local development.
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=solahub_dev;Username=postgres;Password=postgres

# ─── PostgreSQL — PRODUCTION ──────────────────────────────────────────────────
# Production MUST use the solahub_app role (non-superuser) so RLS is enforced.
# Run migrations through a privileged migration connection, then run traffic
# through the app role. Database__AppRolePassword is consumed during migration
# only to set the role password; keep it in your secrets manager.
# ConnectionStrings__DefaultConnection=Host=<host>;Port=5432;Database=solahub_prod;Username=solahub_app;Password=<strong-random-password>
# ConnectionStrings__MigrationConnection=Host=<host>;Port=5432;Database=solahub_prod;Username=<migration_user>;Password=<migration_password>
# Database__AppRolePassword=<same-strong-random-password>

# JWT (minimum 32-character secret)
# Jwt__SecretKey=REPLACE_WITH_A_STRONG_SECRET_OF_AT_LEAST_32_CHARS
# Jwt__Issuer=SolaHub
# Jwt__Audience=SolaHub.Desktop
# Jwt__AccessTokenExpiryMinutes=60

# Redis (optional — omit to disable distributed caching)
# ConnectionStrings__Redis=localhost:6379

# CORS origins (comma-separated). Required in Production; dev/test use built-in defaults when unset.
# Cors__AllowedOrigins=https://tauri.localhost,tauri://localhost

# Forwarded headers. Prefer explicit edge proxy IPs/CIDRs. Only set
# AllowUnknownProxies=true if the API is unreachable except through a trusted
# platform edge that does not publish stable proxy addresses.
# ForwardedHeaders__KnownProxies__0=203.0.113.10
# ForwardedHeaders__KnownNetworks__0=10.0.0.0/8
# ForwardedHeaders__AllowUnknownProxies=false

# Migrations run automatically in dev/test. In production they run via Railway's
# releaseCommand (dotnet SolaHub.API.dll --migrate) before traffic is switched.
# Do NOT set this to true in production.
# Database__ApplyMigrationsOnStartup=false
