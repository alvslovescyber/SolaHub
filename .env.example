# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the SolaHub API. In Tauri production builds this will be the
# localhost port your API is running on. The tauri:// scheme is blocked for CORS
# so use http://localhost:PORT for development.
VITE_API_URL=http://localhost:5000

# ─── API (appsettings.Development.json / environment variables) ───────────────
# These are set in appsettings.json / appsettings.Development.json or via
# environment variables. Copy the values below into your shell or a local
# docker-compose.override.yml file.

# PostgreSQL
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=solahub;Username=postgres;Password=yourpassword

# JWT (minimum 32-character secret)
# Jwt__SecretKey=REPLACE_WITH_A_STRONG_SECRET_OF_AT_LEAST_32_CHARS
# Jwt__Issuer=SolaHubAPI
# Jwt__Audience=SolaHubApp
# Jwt__AccessTokenExpiryMinutes=15

# Redis (optional — omit to disable distributed caching)
# ConnectionStrings__Redis=localhost:6379

# CORS origins (comma-separated, matched against request Origin header)
# Cors__AllowedOrigins=http://localhost:1420,tauri://localhost
